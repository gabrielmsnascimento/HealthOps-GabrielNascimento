:root{--bg:#F4F1EB;--card:#fff;--ink:#0b1720;--muted:#65717c;--brand:#23404A;--copper:#B06D42;--ok:#2f8f56;--warn:#d49400;--bad:#c43b3b;--line:#ded8cf;--r:18px}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--ink);font-family:Inter,system-ui,Segoe UI,Arial,sans-serif}.wrap{max-width:1100px;margin:auto;padding:18px 18px 92px}.eyebrow{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--copper);font-weight:800}h1{font-size:clamp(36px,6vw,60px);line-height:.92;margin:8px 0 10px}h2{margin:0 0 12px}.sub{color:var(--muted)}.grid{display:grid;gap:14px}.cards{grid-template-columns:repeat(4,minmax(0,1fr))}.card{background:var(--card);border-radius:var(--r);padding:18px;box-shadow:0 10px 28px rgba(0,0,0,.05)}.metric{font-size:36px;font-weight:900;color:#123746}.nav{position:fixed;left:0;right:0;bottom:0;background:rgba(244,241,235,.94);backdrop-filter:blur(10px);display:flex;gap:8px;justify-content:center;padding:10px;z-index:20}.nav button,.btn{border:0;border-radius:16px;padding:14px 18px;font-weight:800;background:#e7e3dc;color:#56606a}.nav button.active,.btn.primary{background:var(--brand);color:white}.btn.danger{background:#b33e3e;color:white}input,select,textarea{width:100%;border:1px solid #cfc8bd;border-radius:14px;padding:12px;background:white;font:inherit}textarea{min-height:140px}.table{width:100%;border-collapse:collapse}.table td,.table th{border-bottom:1px solid var(--line);padding:10px;text-align:left}.pill{display:inline-flex;border-radius:999px;padding:5px 9px;margin:3px;background:#eef1f2;font-weight:800;font-size:12px}.pill.ok{background:#e1f3e8;color:var(--ok)}.pill.warn{background:#fff1c7;color:#9b6b00}.pill.bad{background:#ffe4e4;color:var(--bad)}.pill.flight{background:#e5f2ff;color:#17649b}.row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}.med-card{border:1px solid var(--line);border-radius:16px;padding:14px;background:white;cursor:pointer}.med-card:hover{border-color:var(--brand)}.two{grid-template-columns:1fr 1fr}.calendar{display:grid;grid-template-columns:repeat(7,1fr);gap:8px}.day{min-height:72px;border:1px solid var(--line);border-radius:14px;padding:8px;background:white}.day.muted{opacity:.45}.modal{position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;align-items:center;justify-content:center;padding:18px;z-index:30}.modal.on{display:flex}.modal .card{max-width:560px;width:100%}.error{background:#101b22;color:white;border-radius:14px;padding:12px;white-space:pre-wrap;overflow:auto}@media(max-width:760px){.wrap{padding:14px 12px 92px}.cards,.two{grid-template-columns:1fr 1fr}.table{font-size:13px}.table td:nth-child(3),.table th:nth-child(3){display:none}.nav{overflow:auto;justify-content:flex-start}.nav button{padding:12px 14px}.calendar{gap:5px}.day{min-height:58px;font-size:12px}h1{font-size:42px}}@media(max-width:440px){.cards{grid-template-columns:1fr 1fr}.metric{font-size:30px}.card{padding:14px}}
